APP_NAME=AI Product Knowledge Assistant
ENVIRONMENT=development
LOG_LEVEL=INFO
DATA_FILE=data/products.json
CHUNKS_OUTPUT_FILE=data/product_chunks.json
EMBEDDINGS_OUTPUT_FILE=data/product_embeddings.json
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=10
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
SAMPLE_QUERY=I need a breathable white cotton shirt for everyday use.
TOP_K_RESULTS=3
CHUNK_SIZE=4
CHUNK_OVERLAP=1
